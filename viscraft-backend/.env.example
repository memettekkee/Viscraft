# Application
APP_PORT=8080
APP_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viscraft
DB_USER=postgres
DB_PASSWORD=your_db_password

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash-preview-image-generation

# Storage
STORAGE_PATH=/app/storage/images

# JWT Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=24h
